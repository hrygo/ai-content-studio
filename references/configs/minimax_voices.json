{
    "_meta": {
        "model_family": "T2A V2 (speech-2.8-hd / speech-2.6-hd / speech-02-hd / speech-01-hd)",
        "api_doc": "https://platform.minimax.io/docs/api-reference/speech-t2a-http",
        "voice_source": "MiniMax 官方音色（系统音色 + AI 生成音色），完整列表请调用音色查询 API",
        "note": "音色 ID 以 API 返回为准，speech-2.6+ 系列音色命名格式不同于 speech-2.8-hd"
    },

    "_parameter_guide": {
        "voice_id": {
            "description": "音色 ID，标识具体音色",
            "examples": ["male-qn-qingse", "female-yujie", "English_expressive_narrator"]
        },
        "speed": {
            "description": "语速倍率",
            "range": [0.5, 2.0],
            "default": 1.0,
            "examples": {"慢速叙述": 0.85, "标准播报": 1.0, "快速节奏": 1.2, "倍速摘要": 1.5}
        },
        "pitch": {
            "description": "音调调整（半音程）",
            "range": [-12, 12],
            "examples": {"低沉磁性": -3, "标准": 0, "明亮活泼": 3}
        },
        "vol": {
            "description": "音量",
            "range": "(0, 10]",
            "default": 1.0
        },
        "emotion": {
            "description": "情感控制（仅 speech-2.8-hd/turbo 支持）",
            "options": ["happy", "sad", "angry", "fearful", "disgusted", "surprised", "calm", "fluent"],
            "note": "空值由模型自动选择"
        },
        "english_normalization": {
            "description": "英文数字规范化（改善英文数字朗读，略微增加延迟）",
            "default": false
        },
        "latex_read": {
            "description": "LaTeX 公式朗读（需用 $$ 包裹公式，backlash 需转义）",
            "default": false
        },
        "language_boost": {
            "description": "语种增强，优先识别指定语言/方言",
            "options": [
                "Chinese", "Chinese,Yue", "English", "Arabic", "Russian", "Spanish",
                "French", "Portuguese", "German", "Turkish", "Dutch", "Ukrainian",
                "Vietnamese", "Indonesian", "Japanese", "Italian", "Korean", "Thai",
                "Polish", "Romanian", "Greek", "Czech", "Finnish", "Hindi",
                "Bulgarian", "Danish", "Hebrew", "Malay", "Persian",
                "Slovak", "Swedish", "Croatian", "Filipino", "Hungarian",
                "Norwegian", "Slovenian", "Catalan", "Nynorsk", "Tamil",
                "Afrikaans", "auto"
            ]
        },
        "pronunciation_dict": {
            "description": "自定义读音词典",
            "example": {"tone": ["AI/Artificial Intelligence", "LLM/Large Language Model"]}
        },
        "voice_modify": {
            "description": "声音修饰效果",
            "fields": {
                "pitch": "音调（需配合 voice_modify 使用，范围 -24~24）",
                "intensity": "强度（-24~24）",
                "timbre": "音色（-24~24）",
                "sound_effects": "音效，如 spacious_echo"
            },
            "examples": {
                "空旷回声": {"pitch": 0, "intensity": 0, "timbre": 0, "sound_effects": "spacious_echo"}
            }
        }
    },

